<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Expense.
    -->
    <changeSet id="20260420090846-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="business_id"
                                 baseTableName="expense"
                                 constraintName="fk_expense__business_id"
                                 referencedColumnNames="id"
                                 referencedTableName="business"
                                 />

        <addForeignKeyConstraint baseColumnNames="party_id"
                                 baseTableName="expense"
                                 constraintName="fk_expense__party_id"
                                 referencedColumnNames="id"
                                 referencedTableName="party"
                                 />

        <addForeignKeyConstraint baseColumnNames="account_id"
                                 baseTableName="expense"
                                 constraintName="fk_expense__account_id"
                                 referencedColumnNames="id"
                                 referencedTableName="account"
                                 />
    </changeSet>
</databaseChangeLog>
